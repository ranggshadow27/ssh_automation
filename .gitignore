# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Distribution / packaging
*.egg-info/
dist/
build/
*.egg

# Logs & temporary files
*.log
mikrotik_ssh_log.txt
*.txt

# Excel temporary files (kalau lagi dibuka)
~$*.xlsx
~$*.xls

# Environment variables / credentials (jangan di-upload!)
.env
*.env

# Virtual Environment
venv/
env/
ENV/
.venv/

# IDE / Editor files
.vscode/
.idea/
*.swp
*.swo
*~

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Jupyter Notebook
.ipynb_checkpoints

# PyInstaller / cx_Freeze
# Usually these files are written by a python script from a template
# before PyInstaller builds the exe, so as to inject date/other infos into it.
*.manifest
*.spec

# Installer logs
pip-log.txt
pip-delete-this-directory.txt